{
    "name": "amr-control-center",
    "version": "1.0.0",
    "description": "AMR Control Center - Desktop application for controlling Autonomous Mobile Robots",
    "main": "main_process/main.js",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
        "electron:build": "vite build && electron-builder",
        "electron:preview": "vite build && electron ."
    },
    "keywords": [
        "amr",
        "robot",
        "ros2",
        "control",
        "desktop"
    ],
    "author": "AMR Developer",
    "license": "MIT",
    "dependencies": {
        "@react-three/drei": "^9.122.0",
        "@react-three/fiber": "^8.18.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-resizable-panels": "^4.6.5",
        "recharts": "^3.7.0",
        "roslib": "^1.3.0",
        "three": "^0.160.1",
        "zustand": "^4.4.7"
    },
    "devDependencies": {
        "@types/react": "^18.2.43",
        "@types/react-dom": "^18.2.17",
        "@vitejs/plugin-react": "^4.2.1",
        "concurrently": "^8.2.2",
        "cross-env": "^10.1.0",
        "electron": "^28.1.0",
        "electron-builder": "^24.9.1",
        "vite": "^5.0.10",
        "vite-plugin-pwa": "^1.2.0",
        "wait-on": "^7.2.0"
    },
    "build": {
        "appId": "com.amr.control-center",
        "productName": "AMR Control Center",
        "directories": {
            "output": "dist-electron"
        },
        "files": [
            "dist/**/*",
            "main_process/**/*"
        ],
        "win": {
            "target": "nsis",
            "icon": "public/icon.ico"
        },
        "linux": {
            "target": "AppImage",
            "icon": "public/icon.png"
        },
        "mac": {
            "target": "dmg",
            "icon": "public/icon.icns"
        }
    }
}
